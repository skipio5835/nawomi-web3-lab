{
  "name": "circle",
  "version": "1.0.0",
  "description": "Arc Testnet Circle Contracts deployment scripts",
  "scripts": {
    "generate-entity-secret": "tsx circle/arc/scripts/generate-entity-secret.ts",
    "register-entity-secret": "tsx --env-file-if-exists=.env circle/arc/scripts/register-entity-secret.ts",
    "compile-custom": "tsx circle/arc/scripts/compile-custom-contracts.ts",
    "start-deployer": "tsx --env-file-if-exists=.env circle/arc/scripts/serve-deployer.ts",
    "verify-skipio": "tsx circle/arc/scripts/verify-skipio-arcscan.ts",
    "verify-skipio-legacy": "tsx circle/arc/scripts/verify-skipio-legacy.ts",
    "verify-skipio-sourcify": "tsx circle/arc/scripts/verify-skipio-sourcify.ts",
    "verify-skipio-arcscan-sourcify": "tsx circle/arc/scripts/verify-skipio-arcscan-sourcify.ts",
    "build-appkit-send": "node circle/arc/scripts/build-browser.mjs appkit-send",
    "build-appkit-swap": "node circle/arc/scripts/build-browser.mjs appkit-swap",
    "build-appkit-bridge": "node circle/arc/scripts/build-browser.mjs appkit-bridge",
    "build-appkit-unified": "node circle/arc/scripts/build-browser.mjs appkit-unified",
    "build-arc-usdc-tools": "node circle/arc/scripts/build-browser.mjs arc-usdc-tools",
    "build-arc-invoice": "node circle/arc/scripts/build-browser.mjs arc-invoice",
    "build-arc-escrow": "node circle/arc/scripts/build-browser.mjs arc-escrow",
    "build-arc-subscription": "node circle/arc/scripts/build-browser.mjs arc-subscription",
    "build-raw-cctp": "node circle/arc/scripts/build-browser.mjs raw-cctp",
    "cycle:prepare": "npm run compile-custom && npm run build-appkit-send && npm run build-appkit-swap && npm run build-appkit-bridge && npm run build-appkit-unified && npm run build-arc-usdc-tools && npm run build-arc-invoice && npm run build-arc-escrow && npm run build-arc-subscription && npm run build-raw-cctp && npm run typecheck && npm run cycle:checklist",
    "cycle:checklist": "tsx --env-file-if-exists=.env circle/arc/scripts/weekly-cycle.ts",
    "cycle:today": "npm run cycle:checklist",
    "bridge-usdc": "tsx --env-file-if-exists=.env circle/arc/scripts/bridge-usdc.ts",
    "create-wallet": "tsx --env-file-if-exists=.env circle/arc/scripts/create-wallet.ts",
    "deploy-erc20": "tsx --env-file-if-exists=.env circle/arc/scripts/deploy-template.ts erc20",
    "deploy-erc721": "tsx --env-file-if-exists=.env circle/arc/scripts/deploy-template.ts erc721",
    "deploy-erc1155": "tsx --env-file-if-exists=.env circle/arc/scripts/deploy-template.ts erc1155",
    "deploy-airdrop": "tsx --env-file-if-exists=.env circle/arc/scripts/deploy-template.ts airdrop",
    "deploy-base-token": "tsx --env-file-if-exists=.env base/scripts/deploy-base-token.ts",
    "grant-metamask-roles": "tsx --env-file-if-exists=.env circle/arc/scripts/grant-metamask-roles.ts",
    "mint-token": "tsx --env-file-if-exists=.env circle/arc/scripts/mint-token.ts",
    "dev-wallet-usdc-transfer": "tsx --env-file-if-exists=.env circle/arc/scripts/dev-wallet-usdc-transfer.ts",
    "dev-wallet-transfer-from": "tsx --env-file-if-exists=.env circle/arc/scripts/dev-wallet-transfer-from.ts",
    "check-transaction": "tsx --env-file-if-exists=.env circle/arc/scripts/check-transaction.ts",
    "get-contract": "tsx --env-file-if-exists=.env circle/arc/scripts/get-contract.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@circle-fin/adapter-viem-v2": "^1.11.2",
    "@circle-fin/app-kit": "^1.7.0",
    "@circle-fin/developer-controlled-wallets": "^10.6.0",
    "@circle-fin/smart-contract-platform": "^10.6.0",
    "@openzeppelin/contracts": "^5.6.1",
    "ethers": "^6.16.0",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "solc": "^0.8.35",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
