CIRCLE_API_KEY=YOUR_API_KEY
CIRCLE_ENTITY_SECRET=YOUR_ENTITY_SECRET
CIRCLE_WEB3_API_KEY=YOUR_API_KEY

# Filled after `npm run create-wallet`.
WALLET_ID=
WALLET_ADDRESS=

# Filled after a deploy command returns output.
TRANSACTION_ID=
CONTRACT_ID=
CONTRACT_ADDRESS=
METAMASK_ADDRESS=

# Optional deployment defaults.
FEE_LEVEL=MEDIUM
WALLET_SET_NAME=Arc Testnet Wallet Set
CONTRACT_NAME=
TOKEN_NAME=
TOKEN_SYMBOL=
ROYALTY_PERCENT=0.01
CONTRACT_URI=
PLATFORM_FEE_RECIPIENT=
PLATFORM_FEE_PERCENT=

# Optional idempotency overrides for controlled retries.
WALLET_SET_IDEMPOTENCY_KEY=
WALLET_IDEMPOTENCY_KEY=
DEPLOY_IDEMPOTENCY_KEY=

# Optional App Kit bridge settings.
# Keep private keys in local .env only; never paste them into chat.
BRIDGE_PRIVATE_KEY=
BRIDGE_FROM_CHAIN=Ethereum_Sepolia
BRIDGE_TO_CHAIN=Arc_Testnet
BRIDGE_AMOUNT=1.00
BRIDGE_RECIPIENT_ADDRESS=
BRIDGE_USE_FORWARDER=false

# Optional App Kit Swap key from Circle Console.
KIT_KEY=
